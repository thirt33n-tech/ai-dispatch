# --- Windows アーティファクト ---
*.lnk

# --- secrets（絶対にコミットしない） ---
.env
*.env
.env.*

# --- 半自動パイプライン中間ステージング（pending集約先・メディア） ---
/pending/

# --- 実行ログ（公開サイト repo には含めない） ---
/logs/

# --- 内部状態・キャッシュ ---
.omc/
.claude/
.vscode/
__pycache__/
*.pyc

# --- バックアップ（公開サイトrepoには含めない） ---
*.bak*

# --- 内部実装（公開サイトrepoには含めない・選択肢A）---
/bin/
/ref/
/config/
/assets/minami/_pipeline/
*.orig
*.seed.json
/PHASE1_INSTRUCTIONS.md
/TASK_C_INSTRUCTIONS.md
/PHASE0_SURVEY.md
/PHASE1_DESIGN.md

# --- パイプライン実行時ロック（resolve_news_source.sh が管理） ---
/.locks/
